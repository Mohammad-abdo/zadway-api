{
  "info": {
    "_postman_id": "0c6b1d13-0f6d-4d8c-8b3c-6f2f9bd23b2a",
    "name": "Qarora Backend (Customer + Driver)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Generated collection for Qarora modular REST API. Variables: baseUrl (e.g. http://localhost:6000), tokenCustomer, tokenDriver."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:6000" },
    { "key": "tokenCustomer", "value": "" },
    { "key": "tokenDriver", "value": "" },
    { "key": "customerEmail", "value": "rider@seed.local" },
    { "key": "driverEmail", "value": "driver@seed.local" },
    { "key": "password", "value": "seed-password" },
    { "key": "productId", "value": "1" },
    { "key": "variantId", "value": "1" },
    { "key": "guestId", "value": "1" },
    { "key": "orderId", "value": "1" },
