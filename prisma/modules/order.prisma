enum ProductOrderStatus {
  NEW
  PENDING
  ACCEPTED
  REJECTED
  DELIVERED
}

enum ProductPaymentMethod {
  CASH
}

enum ProductOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model GuestCustomer {
  id        Int      @id @default(autoincrement())
  name      String?
  phone     String?
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(6)

  orders ProductOrder[]

  @@map("guest_customers")
}

model ProductOrder {
  id            Int                 @id @default(autoincrement())
  guestId       Int                 @map("guest_id")
  driverId      Int?                @map("driver_id")
  riderUserId   Int?                @map("rider_user_id")
  accessToken   String?             @unique @map("access_token") @db.VarChar(64)
  status        ProductOrderStatus  @default(NEW)
  paymentMethod ProductPaymentMethod @default(CASH) @map("payment_method")

  dropoffLat   Float   @map("dropoff_lat") @db.Double
  dropoffLng   Float   @map("dropoff_lng") @db.Double
  dropoffNotes String? @map("dropoff_notes") @db.Text
  dropoffNotesI18n Json? @map("dropoff_notes_i18n")

  subtotal      Float  @default(0) @db.Double
  commissionPct Float  @default(0) @map("commission_pct") @db.Double
  commissionAmt Float  @default(0) @map("commission_amt") @db.Double
  total         Float  @default(0) @db.Double
  currency      String @default("SAR") @db.VarChar(8)

  assignedAt  DateTime? @map("assigned_at") @db.Timestamp(0)
  deliveredAt DateTime? @map("delivered_at") @db.Timestamp(0)
  cancelledAt DateTime? @map("cancelled_at") @db.Timestamp(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.DateTime(6)

  guest           GuestCustomer              @relation(fields: [guestId], references: [id])
  rider           User?                      @relation("ProductOrderRider", fields: [riderUserId], references: [id])
  driver          User?                      @relation("ProductOrderDriver", fields: [driverId], references: [id])
  items           ProductOrderItem[]
  offers          ProductOrderOffer[]
  payments        Payment[]
  walletHistories WalletHistory[]
  locationUpdates ProductOrderLocationUpdate[]

  @@index([guestId, status])
  @@index([driverId, status])
  @@index([riderUserId, status])
  @@index([status])
  @@map("Product_orders")
}

model ProductOrderItem {
  id        Int   @id @default(autoincrement())
  orderId   Int   @map("order_id")
  variantId Int   @map("variant_id")
  quantity  Int
  unitPrice Float @map("unit_price") @db.Double
  lineTotal Float @map("line_total") @db.Double

  order   ProductOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
  @@map("Product_order_items")
}

model DriverInventoryItem {
  id             Int      @id @default(autoincrement())
  driverId       Int      @map("driver_id")
  variantId      Int      @map("variant_id")
  quantityOnHand Int      @default(0) @map("quantity_on_hand")
  price          Float    @db.Double
  currency       String   @default("SAR") @db.VarChar(8)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(6)

  driver  User           @relation(fields: [driverId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([driverId, variantId])
  @@index([driverId])
  @@index([variantId])
  @@map("driver_inventory_items")
}

model ProductOrderOffer {
  id           Int               @id @default(autoincrement())
  orderId      Int               @map("order_id")
  driverId     Int               @map("driver_id")
  offeredPrice Float?            @map("offered_price") @db.Double
  status       ProductOfferStatus @default(PENDING)
  createdAt    DateTime          @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt    DateTime          @default(now()) @updatedAt @map("updated_at") @db.DateTime(6)

  order  ProductOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver User         @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([orderId, driverId])
  @@index([orderId, status])
  @@index([driverId, status])
  @@map("Product_order_offers")
}

model Payment {
  id             Int      @id @default(autoincrement())
  ProductOrderId Int      @map("Product_order_id")
  userId         Int      @map("user_id")
  driverId       Int      @map("driver_id")
  amount         Float    @db.Double
  paymentType    String   @map("payment_type")
  paymentStatus  String   @default("pending") @map("payment_status") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.DateTime(6)

  ProductOrder ProductOrder @relation(fields: [ProductOrderId], references: [id], onDelete: Cascade)
  user         User         @relation("PaymentUser", fields: [userId], references: [id])
  driver       User         @relation("PaymentDriver", fields: [driverId], references: [id])

  @@index([ProductOrderId])
  @@index([userId])
  @@index([driverId])
  @@index([paymentStatus])
  @@map("payments")
}

model InventoryLog {
  id        Int      @id @default(autoincrement())
  driverId  Int      @map("driver_id")
  variantId Int      @map("variant_id")
  change    Int
  reason    String   @db.VarChar(191)
  reasonI18n Json?   @map("reason_i18n")
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(6)

  driver  User           @relation(fields: [driverId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([driverId, createdAt])
  @@index([variantId, createdAt])
  @@map("inventory_logs")
}

model ProductOrderLocationUpdate {
  id        Int      @id @default(autoincrement())
  orderId   Int      @map("order_id")
  driverId  Int      @map("driver_id")
  lat       Float    @db.Double
  lng       Float    @db.Double
  heading   Float?   @db.Double
  speed     Float?   @db.Double
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(6)

  order  ProductOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver User         @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([driverId, createdAt])
  @@map("Product_order_location_updates")
}

enum OrderStatus {
  NEW
  OFFERED
  ACCEPTED
  PICKED_UP
  DELIVERING
  DELIVERED
  CANCELLED
}

